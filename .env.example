# Runtime
NODE_ENV=development
PORT=3000
CLIENT_URL=http://localhost:5173

# Database
# Local:
# MONGO_URI=mongodb://127.0.0.1:27017/screentime-recorder
# Atlas:
MONGO_URI=mongodb+srv://<username>:<password>@<cluster-host>/screentime-recorder?retryWrites=true&w=majority&appName=<AppName>

# Authentication (generate strong random values for production)
SESSION_SECRET=replace_with_a_random_48_byte_hex_string
JWT_SECRET=replace_with_a_different_random_48_byte_hex_string
JWT_EXPIRES_IN=7d

# Google OAuth (optional; local email/password auth works without these)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=http://localhost:3000/api/auth/google/callback

# AI categorization: "groq", "openai", or "fallback"
AI_PROVIDER=groq
AI_MODEL=llama3-8b-8192
GROQ_API_KEY=
OPENAI_API_KEY=
